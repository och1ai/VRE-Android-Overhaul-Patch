<LanguageData>

	<!-- Reasons. These are appended to vanilla's own "Cannot <verb> <thing>: " / "<option> (<reason>)"
	     wrappers, which capitalize or uncapitalize as needed, so they carry no leading capital and no
	     trailing period of their own. -->
	<VREAOverhaul.IsAndroid>{PAWN_nameDef} is an android</VREAOverhaul.IsAndroid>
	<VREAOverhaul.NoOccultistSubroutine>{PAWN_nameDef} has no occultist subroutine</VREAOverhaul.NoOccultistSubroutine>

	<!-- Full sentences shown as their own message. -->
	<VREAOverhaul.CannotConvertAndroid>{PAWN_nameDef} has no ideological subroutine and cannot hold beliefs.</VREAOverhaul.CannotConvertAndroid>

	<!-- Inspect pane. -->
	<VREAOverhaul.ShuttingDownIn>Shutting down in {0}</VREAOverhaul.ShuttingDownIn>

