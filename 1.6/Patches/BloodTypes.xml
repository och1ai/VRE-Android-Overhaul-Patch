<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- Blood becomes a choice of three. The original's neutro circulation is retuned in place into one of
	     the options (same defName, so existing androids migrate for free) and joins the AndroidBlood
	     exclusion group; the other two arrive as new genes. It stays a core component, exactly as the other
	     two blood genes are. -->

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/VREAndroids.AndroidGeneDef[defName="VREA_NeutroCirculation"]/label</xpath>
		<value>
			<label>neutroamine blood</label>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/VREAndroids.AndroidGeneDef[defName="VREA_NeutroCirculation"]/description</xpath>
		<value>
			<description>Replaces the android's blood with neutroamine: the most power-efficient circulatory option, topped up cheaply with neutroamine. Wounds bleed blue neutroamine, and if left unchecked the android can bleed out and die, though its subcore stays recoverable.</description>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/VREAndroids.AndroidGeneDef[defName="VREA_NeutroCirculation"]/biostatCpx</xpath>
		<value>
			<biostatCpx>2</biostatCpx>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/VREAndroids.AndroidGeneDef[defName="VREA_NeutroCirculation"]</xpath>
		<value>
			<biostatMet>12</biostatMet>
			<exclusionTags>
				<li>AndroidBlood</li>
			</exclusionTags>
		</value>
	</Operation>

</Patch>
