<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- 7c psychic sensitivity: base androids should have a faint (0.5) presence, not be fully deaf, so
	     eltex gear works and an occultist can join rituals. Swap the original's psychically-deaf gene for
	     the overlay's "psychically dull" in the base loadout, and drop it entirely from the awakened
	     loadout (awakened androids reach full 1.0 sensitivity). -->

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/XenotypeDef[@Name="VREA_AndroidXenotypeBase"]/genes/li[.="VREA_PsychicallyDeaf"]</xpath>
		<value>
			<li>VREA_MutedPsyche</li>
		</value>
	</Operation>

	<Operation Class="PatchOperationRemove">
		<xpath>Defs/XenotypeDef[@Name="VREA_AndroidXenotypeAwakenedBase"]/genes/li[.="VREA_PsychicallyDeaf"]</xpath>
	</Operation>

</Patch>
