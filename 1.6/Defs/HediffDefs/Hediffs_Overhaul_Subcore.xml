<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<!-- The android subcore, installed in the brain. Hidden from the health list and never removed on its
	     own; its presence is what makes a destroyed android recoverable rather than dead, and sitting in the
	     brain is what makes decapitation a true, permanent kill. -->
	<HediffDef>
		<defName>VREA_AndroidSubcoreImplant</defName>
		<label>android subcore</label>
		<description>The android's subcore: a psychodynamic substrate that stores this android's identity. It can be recovered from the body, even after death, and used to reprint or resurrect the same android.</description>
		<hediffClass>VREAndroidsOverhaul.Hediff_AndroidSubcore</hediffClass>
		<defaultLabelColor>(0.6, 0.85, 1.0)</defaultLabelColor>
		<isBad>false</isBad>
		<initialSeverity>1</initialSeverity>
		<maxSeverity>1</maxSeverity>
		<scenarioCanAdd>false</scenarioCanAdd>
		<everCurableByItem>false</everCurableByItem>
	</HediffDef>

</Defs>
